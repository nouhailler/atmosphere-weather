#!/bin/bash
# Atmosphere Weather launcher
cd /usr/share/atmosphere-weather
PORT=8080

# Vérifier si le port est déjà utilisé
if lsof -Pi :$PORT -sTCP:LISTEN -t >/dev/null ; then
    echo "Le port $PORT est déjà utilisé. Veuillez fermer l'application qui utilise ce port."
    exit 1
fi

echo "Démarrage du serveur sur http://localhost:$PORT"
python3 -m http.server $PORT &
SERVER_PID=$!

sleep 2
xdg-open "http://localhost:$PORT"

wait $SERVER_PID
